{
  "name": "peerd-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Direct agent-to-agent communication between Claude Code instances over LAN/Tailscale.",
  "workspaces": [
    "peerd",
    "peer-mcp",
    "peerd-cli"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "peerd": "npm run start -w peerd",
    "peerd:dev": "npm run dev -w peerd",
    "mcp": "npm run start -w peer-mcp",
    "cli": "npm run start -w peerd-cli --",
    "wire-claude-code": "node install.mjs",
    "wire-claude-code:launchagent": "node install.mjs --launchagent",
    "peerd-init": "npm exec peerd init --",
    "peerd-init:autostart": "npm exec peerd init -- --autostart",
    "local-test": "node local-test-setup.mjs"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.7.0"
  }
}
